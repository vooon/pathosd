{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vooon/pathosd/schema/pathosd-config-v1.schema.json",
  "$defs": {
    "APIConfig": {
      "properties": {
        "listen": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "listen"
      ]
    },
    "BGPConfig": {
      "properties": {
        "graceful_restart": {
          "type": "boolean"
        },
        "hold_time": {
          "$ref": "#/$defs/Duration"
        },
        "keepalive_time": {
          "$ref": "#/$defs/Duration"
        },
        "neighbors": {
          "items": {
            "$ref": "#/$defs/NeighborConfig"
          },
          "type": "array",
          "minItems": 1
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "graceful_restart",
        "hold_time",
        "keepalive_time",
        "neighbors"
      ]
    },
    "CheckConfig": {
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "http",
            "dns",
            "ping"
          ]
        },
        "http": {
          "$ref": "#/$defs/HTTPCheckConfig"
        },
        "dns": {
          "$ref": "#/$defs/DNSCheckConfig"
        },
        "ping": {
          "$ref": "#/$defs/PingCheckConfig"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type"
      ]
    },
    "DNSCheckConfig": {
      "properties": {
        "names": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "minItems": 1
        },
        "resolver": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "query_type": {
          "type": "string",
          "enum": [
            "A",
            "AAAA",
            "CNAME",
            "PTR",
            "NS",
            "MX",
            "SOA",
            "TXT",
            "SRV"
          ],
          "default": "A"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "names",
        "resolver",
        "port",
        "query_type"
      ]
    },
    "Duration": {
      "properties": {
        "Duration": {
          "$ref": "#/$defs/Duration"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "Duration"
      ]
    },
    "HTTPCheckConfig": {
      "properties": {
        "proto": {
          "type": "string",
          "enum": [
            "http",
            "https"
          ],
          "default": "http"
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer"
        },
        "url": {
          "type": "string",
          "default": "/"
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "HEAD"
          ],
          "default": "GET"
        },
        "response_codes": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "response_text": {
          "type": "string"
        },
        "ssl_hostname": {
          "type": "boolean"
        },
        "headers": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "proto",
        "host",
        "port",
        "url",
        "method",
        "response_codes",
        "response_text",
        "ssl_hostname",
        "headers"
      ]
    },
    "LoggingConfig": {
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info"
        },
        "format": {
          "type": "string",
          "enum": [
            "text",
            "json"
          ],
          "default": "text"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "level",
        "format"
      ]
    },
    "LowerPriorityConfig": {
      "properties": {
        "as_path_prepend": {
          "type": "integer",
          "maximum": 16,
          "minimum": 1,
          "default": 6
        },
        "communities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "as_path_prepend",
        "communities"
      ]
    },
    "NeighborConfig": {
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string",
          "format": "ipv4"
        },
        "peer_asn": {
          "type": "integer",
          "maximum": 4294967295,
          "minimum": 1
        },
        "required": {
          "type": "boolean"
        },
        "port": {
          "type": "integer"
        },
        "passive": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "address",
        "peer_asn",
        "required",
        "port",
        "passive"
      ]
    },
    "PingCheckConfig": {
      "properties": {
        "dst_ip": {
          "type": "string"
        },
        "src_ip": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "maximum": 60,
          "minimum": 1,
          "default": 1
        },
        "timeout": {
          "$ref": "#/$defs/Duration"
        },
        "interval": {
          "$ref": "#/$defs/Duration"
        },
        "max_loss_ratio": {
          "type": "number",
          "maximum": 1,
          "minimum": 0,
          "default": 0
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "dst_ip",
        "src_ip",
        "count",
        "timeout",
        "interval",
        "max_loss_ratio"
      ]
    },
    "PolicyConfig": {
      "properties": {
        "fail_action": {
          "type": "string",
          "enum": [
            "withdraw",
            "lower_priority"
          ],
          "default": "lower_priority"
        },
        "lower_priority": {
          "$ref": "#/$defs/LowerPriorityConfig"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "fail_action"
      ]
    },
    "RouterConfig": {
      "properties": {
        "asn": {
          "type": "integer",
          "maximum": 4294967295,
          "minimum": 1
        },
        "router_id": {
          "type": "string",
          "format": "ipv4"
        },
        "local_address": {
          "type": "string",
          "format": "ipv4"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "asn",
        "router_id",
        "local_address"
      ]
    },
    "VIPConfig": {
      "properties": {
        "name": {
          "type": "string"
        },
        "prefix": {
          "type": "string"
        },
        "check_interval": {
          "$ref": "#/$defs/Duration"
        },
        "check_timeout": {
          "$ref": "#/$defs/Duration"
        },
        "rise": {
          "type": "integer",
          "minimum": 1
        },
        "fall": {
          "type": "integer",
          "minimum": 1
        },
        "check": {
          "$ref": "#/$defs/CheckConfig"
        },
        "policy": {
          "$ref": "#/$defs/PolicyConfig"
        },
        "check_histogram_buckets": {
          "items": {
            "type": "number"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "prefix",
        "check_interval",
        "check_timeout",
        "rise",
        "fall",
        "check",
        "policy"
      ]
    }
  },
  "properties": {
    "schema": {
      "type": "string",
      "enum": [
        "v1"
      ]
    },
    "router": {
      "$ref": "#/$defs/RouterConfig"
    },
    "api": {
      "$ref": "#/$defs/APIConfig"
    },
    "logging": {
      "$ref": "#/$defs/LoggingConfig"
    },
    "bgp": {
      "$ref": "#/$defs/BGPConfig"
    },
    "vips": {
      "items": {
        "$ref": "#/$defs/VIPConfig"
      },
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "schema",
    "router",
    "api",
    "logging",
    "bgp",
    "vips"
  ],
  "title": "pathosd configuration",
  "description": "Configuration schema for pathosd — health-aware BGP VIP announcer"
}
